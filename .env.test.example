# Test environment template — copy to `.env.test` and fill in values.
# Used by the E2E suite (jest-e2e). Keep the DB + Redis logical DB
# separate from dev so tests NEVER touch dev data.

DATABASE_URL="postgresql://agent_saas_app:<app-password>@localhost:5432/agent_saas_test"
MIGRATION_DATABASE_URL="postgresql://<db-superuser>@localhost:5432/agent_saas_test"
OUTBOX_DATABASE_URL="postgresql://outbox_worker:<outbox-password>@localhost:5432/agent_saas_test?connection_limit=3"

JWT_SECRET="<generate-with: openssl rand -base64 32>"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB_QUEUES=15
REDIS_DB_REALTIME=14

PORT=3999
NODE_ENV=test
LOG_LEVEL=silent

# Tests run fast — raise throttle so a full-suite run doesn't trip 429s.
# Both tiers raised to 10k for the general suite; the rate-limit-specific
# E2E spec uses tenant headers / unique API keys per case so it can
# exercise the limits without polluting other tests.
THROTTLER_GLOBAL_LIMIT=10000
THROTTLER_GLOBAL_TTL_MS=60000
THROTTLER_TENANT_LIMIT=10000
THROTTLER_TENANT_TTL_MS=60000
